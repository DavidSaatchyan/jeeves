# Required — the app will refuse to start without these
OPENAI_API_KEY=sk-...
JWT_SECRET=your-random-string-at-least-32-characters-long
DATABASE_URL=postgresql+psycopg2://jeeves:your-strong-db-password@postgres:5432/jeeves
POSTGRES_PASSWORD=your-strong-db-password

# Optional
REDIS_URL=redis://redis:6379/0
CHROMA_PATH=/data/chroma
PUBLIC_BASE_URL=http://localhost:8000
KNOWLEDGE_DIR=/app/knowledge
FERNET_KEY=your-32-char-fernet-key-for-credential-encryption

# SMTP for transactional emails (email verification, notifications)
# Leave empty to print verification links to console (dev mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@jeeves.ai
SMTP_USE_TLS=true

# HubSpot OAuth (only if using HubSpot CRM)
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:8000/crm/oauth/hubspot/callback
