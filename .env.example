# Required — the app will refuse to start without these
OPENAI_API_KEY=sk-...
JWT_SECRET=your-random-string-at-least-32-characters-long
DATABASE_URL=postgresql+psycopg2://jeeves:your-password@localhost:5432/jeeves

# Optional
REDIS_URL=redis://localhost:6379/0
CHROMA_PATH=./chroma_data
PUBLIC_BASE_URL=http://localhost:8000
KNOWLEDGE_DIR=./knowledge
FERNET_KEY=your-32-char-fernet-key-for-credential-encryption

# Stripe (Payment Recovery)
STRIPE_SECRET_KEY=sk_...

# SendGrid (Email delivery)
SENDGRID_API_KEY=

# Resend (alternative email provider)
RESEND_API_KEY=

# Recharge (Subscription management — Cancellation Save)
RECHARGE_API_KEY=

# Shopify (Order/shipment data — WISMO)
SHOPIFY_SHOP=mystore.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_...
